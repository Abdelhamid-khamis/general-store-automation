{
  "name": "general-store-automation",
  "version": "1.0.0",
  "description": "Mobile automation for General Store Android app using WebdriverIO + Appium 2 + TypeScript + Mocha",
  "main": "index.js",
  "scripts": {
    "test": "npx wdio run wdio.conf.ts",
    "test:report": "npx wdio run wdio.conf.ts && npm run report",
    "report": "node scripts/mergeReports.js && npx marge reports/json/merged.json --reportDir reports/html --reportFilename index",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "appium",
    "webdriverio",
    "mobile",
    "automation",
    "typescript",
    "mocha"
  ],
  "author": "SDET",
  "license": "MIT",
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "@wdio/appium-service": "^8.29.1",
    "@wdio/cli": "^8.29.1",
    "@wdio/local-runner": "^8.29.1",
    "@wdio/mocha-framework": "^8.29.1",
    "@wdio/spec-reporter": "^8.29.1",
    "eslint": "^8.56.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^3.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "wdio-mochawesome-reporter": "^3.2.0"
  },
  "dependencies": {
    "webdriverio": "^8.29.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}