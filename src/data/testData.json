{
  "testCases": [
    {
      "id": "TC_001",
      "description": "Complete General Store purchase flow — Male user from Andorra",
      "user": {
        "name": "Abdelhamid Khamis",
        "country": "Andorra",
        "gender": "Male"
      },
      "product": {
        "strategy": "Second_available",
        "addToCartButtonIndex": 0
