      "assertions": {
        "cartScreenTitle": "My Cart",
        "productMustBeInCart": true
      }
    }
  ],
  "appConfig": {
    "appPackage": "com.androidsample.generalstore",
    "splashActivity": "com.androidsample.generalstore.SplashActivity",
    "mainActivity": "com.androidsample.generalstore.MainActivity",
    "productsActivity": "com.androidsample.generalstore.AllProductsActivity",
    "cartActivity": "com.androidsample.generalstore.CartActivity",
    "splashWaitMs": 5000
  }
}
