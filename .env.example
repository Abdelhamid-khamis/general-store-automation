# General Store Automation — Environment Configuration
# Copy this to .env and fill in your values.
# .env is gitignored — never commit actual values.

# ─── Appium ──────────────────────────────────────────────────────────────────
APPIUM_HOST=localhost
APPIUM_PORT=4723

# ─── Android Emulator ────────────────────────────────────────────────────────
DEVICE_NAME=emulator-5554
PLATFORM_VERSION=14.0

# ─── App ─────────────────────────────────────────────────────────────────────
# Leave blank to use default: <project_root>/apps/General-Store.apk
APP_PATH=

# ─── OrangeHRM API Tests (Playwright) ────────────────────────────────────────
# Public demo credentials — safe to commit as defaults for this demo site
ORANGEHRM_BASE_URL=https://opensource-demo.orangehrmlive.com
ORANGEHRM_USERNAME=Admin
ORANGEHRM_PASSWORD=admin123
